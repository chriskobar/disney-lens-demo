# Copy this file to .env.local and fill in your keys
# Get your Anthropic API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Get your ElevenLabs API key at https://elevenlabs.io/app/settings
ELEVENLABS_API_KEY=xxxxx

# Optional: ElevenLabs voice ID (defaults to a warm narrator voice)
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=
